# Energy-Oracle Environment Configuration
# Copy this file to .env and fill in values before running

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite for local dev (default):
DATABASE_URL=sqlite:///./energy_oracle.db
# PostgreSQL for production:
# DATABASE_URL=postgresql://oracle:your_password@localhost:5432/energy_oracle

# ── Model ────────────────────────────────────────────────────────────────────
MODEL_PATH=model.joblib
METRICS_PATH=metrics.json
MODEL_VERSION=1.1.0

# ── API ──────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
RATE_LIMIT_PER_MINUTE=60

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (default: all)
CORS_ORIGINS=*

# ── Batch ─────────────────────────────────────────────────────────────────────
MAX_BATCH_SIZE=1000

# ── Observability ─────────────────────────────────────────────────────────────
# Set to true to emit structured JSON log lines
ENABLE_JSON_LOGS=false
# Number of recent predictions used in drift detection
DRIFT_WINDOW_SIZE=100

# ── Retraining ────────────────────────────────────────────────────────────────
# RMSE threshold above which a retrained model is rejected
RMSE_THRESHOLD=20.0

# ── Blending ─────────────────────────────────────────────────────────────────
# Weight for LightGBM vs RandomForest (0.0–1.0)
BLEND_ALPHA=0.7
