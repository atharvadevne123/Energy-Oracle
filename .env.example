# Energy-Oracle Environment Configuration
# Copy this file to .env and fill in values before running

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite for local dev (default):
DATABASE_URL=sqlite:///./energy_oracle.db
# PostgreSQL for production:
# DATABASE_URL=postgresql://oracle:your_password@localhost:5432/energy_oracle

# ── Model ────────────────────────────────────────────────────────────────────
MODEL_PATH=model.joblib
METRICS_PATH=metrics.json

# ── API ──────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
RATE_LIMIT_PER_MINUTE=60

# ── Retraining ────────────────────────────────────────────────────────────────
# RMSE threshold above which a retrained model is rejected
RMSE_THRESHOLD=20.0
